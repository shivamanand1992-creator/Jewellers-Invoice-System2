# Required — Postgres connection string (Railway provides this automatically via the Postgres plugin)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Required — any random secret string (used for sessions)
SESSION_SECRET=your-random-secret-here

# Required — from clerk.com → your app → API Keys
CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxx

# Required — same value as CLERK_PUBLISHABLE_KEY (used by the frontend at build time)
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx
